{"nodes": [{"id": "design_EE_Assistant", "label": "EE Assistant Application", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Targets professional electrical engineers in industrial automation. Siemens S7-1200/S7-1500 first, architecture reserves multi-brand extension. Chat-driven requirements analysis with RAG-based component selection, block-diagram schematics, and PLC ST code generation deployed via Docker Compose."}, {"id": "design_MVS_Architecture", "label": "MVS Architecture Pattern", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Frontend uses MVS: Models (Zustand store + TypeScript types), Views (React components), Services (API client, WebSocket, export, analysis flow). Separation allows independent testing and clean data flow."}, {"id": "design_Component_Selection_Engine", "label": "Component Selection Engine", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Flow: Category Mapping (LLM) -> RAG Search (Qdrant) -> LLM Supplement -> Rule Engine Validation -> BOM Output with tiered confidence. Five hard constraints: breaker rating >= 1.25x load, SIL2+ redundancy, protocol compatibility, voltage matching, motor starter match."}, {"id": "design_Rule_Engine", "label": "Rule Engine (5 Hard Constraints)", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "design_RAG_Knowledge_Base", "label": "RAG Knowledge Base", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "PDF upload with drag-and-drop, PyMuPDF extraction, smart chunking at section/table boundaries, embedding via text-embedding-3-small, Qdrant vector storage. Tag system: manufacturer, category, model series. Filter by tag first, then semantic search."}, {"id": "design_Tiered_Confidence_Display", "label": "Tiered Confidence Display (rag/llm/mixed)", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "design_Requirements_Analysis", "label": "Requirements Analysis Stage", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "design_Schematic_Generation", "label": "Schematic Generation Stage", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Block-diagram level using Mermaid generation with interactive overlay. LLM generates Mermaid flowchart from BOM + control logic. Frontend renders via react-mermaid with click/tooltip overlay. Export to SVG, PNG, PDF, direct print."}, {"id": "design_ST_Code_Generation", "label": "ST Code Generation Stage", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Output: program structure (FC/FB/OB decomposition), IO mapping table (TIA Portal %I/%Q/%IW/%QW), FC/FB code skeleton. Safety logic always complete (E-Stop, safety door, interlocks). Regular logic: framework + comments. Monaco Editor with ST syntax highlighting and module tree sidebar."}, {"id": "design_Orchestrator", "label": "Orchestrator (Backend Workflow State Machine)", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "design_Component_Selection_Engine", "target": "design_Rule_Engine", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "weight": 1.0}, {"source": "design_Component_Selection_Engine", "target": "design_RAG_Knowledge_Base", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.9, "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "weight": 1.0}, {"source": "design_Orchestrator", "target": "design_Requirements_Analysis", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "weight": 1.0}, {"source": "design_Orchestrator", "target": "design_Schematic_Generation", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.8, "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "weight": 1.0}, {"source": "design_Orchestrator", "target": "design_ST_Code_Generation", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.8, "source_file": "docs/superpowers/specs/2026-05-01-ee-assistant-design.md", "source_location": null, "weight": 1.0}, {"source": "design_Orchestrator", "target": "design_Component_Selection_Engine", "relation": "conceptually_re