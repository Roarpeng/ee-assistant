# ============================================================================
# EE Assistant — 后端环境变量样例
#
# 复制为 .env 后, docker compose up 时会自动通过 backend.env_file 注入。
# 推荐工作流: 大部分用户在 UI (设置弹窗) 中配置 LLM, 此处仅留作"开机默认厂商"
# 兜底, 因此可以全部留空。
# ============================================================================

# -- 数据库 / 存储 (默认值已经匹配 docker-compose.yml, 一般无需改) --
# DATABASE_URL=postgresql+asyncpg://ele:ele@postgres:5432/ele
# QDRANT_URL=http://qdrant:6333
# QDRANT_COLLECTION=ee_knowledge
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=knowledge-docs

# ============================================================================
# Chat LLM (按优先级从上到下取第一个非空)
# ----------------------------------------------------------------------------
# 1. 通用 OpenAI 兼容三件套 — 任何支持 /v1/chat/completions 的厂商都用这个
# CHAT_API_KEY=
# CHAT_BASE_URL=https://api.openai.com/v1
# CHAT_MODEL=gpt-4o

# 2. 国内厂商专用 alias — 仅设这一个, base_url 会自动回填到对应厂商官方端点
#    (前端 UI 选中"百炼"/"火山方舟"会自动填好这些, 后端这里只是 ops 兜底)

# 阿里云百炼 (DashScope OpenAI 兼容模式)
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxx
# 也可写成: BAILIAN_API_KEY=sk-xxxxxxxxxxxx

# 火山方舟 (Volcengine Ark)
# ARK_API_KEY=xxxxxxxxxxxx
# 也可写成: VOLCANO_API_KEY=xxxxxxxxxxxx

# 3. 其他历史 alias (仍兼容)
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# LLM_MODEL=
# LLM_MAX_TOKENS=4096

# ============================================================================
# Embedding LLM (优先级同上)
# ----------------------------------------------------------------------------
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=4096
#
# 厂商提示:
# - DashScope text-embedding-v3 原生 1024 维, 服务端会自动 clamp 到 1024
# - Volcengine doubao-embedding-text-240715 原生 2560 维, 不接受 dimensions 参数
# - 切换 EMBEDDING_DIM 后 Qdrant collection 会被重建, 已入库的知识需要重跑
